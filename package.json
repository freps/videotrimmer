{
  "name": "video-trimmer",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "pack": "npm run build:main && npm run build:renderer && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "build:win": "npm run build:main && npm run build:renderer && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^25.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "dev.videotrimmer.app",
    "productName": "VideoTrimmer",
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "mac": {
      "target": "dmg",
      "fileAssociations": [
        {
          "ext": ["mp4", "mov", "avi", "mkv", "webm", "m4v"],
          "name": "Video",
          "role": "Viewer"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "extraResources": [
        {
          "from": "build/ffmpeg.exe",
          "to": "ffmpeg.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
